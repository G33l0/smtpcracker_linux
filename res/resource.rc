#include <windows.h>
#include "../include/resource.h"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION     1,1,0
 PRODUCTVERSION  1,1,0
 FILEFLAGSMASK   0x3fL
#ifdef _DEBUG
 FILEFLAGS       0x1L
#else
 FILEFLAGS       0x0L
#endif
 FILEOS          VOS__WINDOWS32
 FILETYPE        VFT_APP
 FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "SHKA\0"
            VALUE "FileDescription",  "Smtp Cracker v1.1.0\0"
            VALUE "FileVersion",      "1.1.0\0"
            VALUE "InternalName",     "smtpcracker.exe\0"
            VALUE "LegalCopyright",   "Copyright (C) 2026. All rights reserved.\0"
            VALUE "OriginalFilename", "smtpcracker.exe\0"
            VALUE "ProductName",      "Smtp Cracker\0"
            VALUE "ProductVersion",   "1.1.0\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

